# Copiar este archivo como .env y rellenar los valores reales.
# NUNCA commitear .env con credenciales reales.

# Secret para firmar tokens JWT. Debe ser un string largo y aleatorio.
APP_AUTH_JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# DSN de la base de datos PostgreSQL.
APP_DATABASE_DSN=postgres://app:CHANGE_ME@postgres:5432/app_db

# Credenciales de PostgreSQL (usadas por el servicio postgres en docker-compose).
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=app_db
